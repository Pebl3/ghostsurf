#!/bin/bash
# ghostsurf - Entry point with auto-bootstrap

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")")" && pwd)"
VENV_DIR="$SCRIPT_DIR/venv"

# Auto-setup venv on first run
if [ ! -d "$VENV_DIR" ]; then
    if ! command -v python3 &> /dev/null; then
        echo "Error: python3 is required but not installed."
        exit 1
    fi

    echo "[*] First run — setting up virtual environment..."
    python3 -m venv "$VENV_DIR" || { echo "Error: Failed to create venv."; exit 1; }

    source "$VENV_DIR/bin/activate"
    pip install --upgrade pip > /dev/null 2>&1
    echo "[*] Installing dependencies..."
    pip install -r "$SCRIPT_DIR/requirements.txt" || { echo "Error: Failed to install dependencies."; exit 1; }

    echo "[*] Setup complete."
    echo ""
else
    source "$VENV_DIR/bin/activate"
fi

exec python "$SCRIPT_DIR/ghostsurf.py" "$@"
